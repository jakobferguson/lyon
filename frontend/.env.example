# Azure AD — obtain from Azure Portal > App Registrations
VITE_MSAL_CLIENT_ID=your-client-id-here
VITE_MSAL_TENANT_ID=your-tenant-id-here
VITE_MSAL_REDIRECT_URI=http://localhost:5173

# API base URL — defaults to http://localhost:5000 if not set
VITE_API_URL=http://localhost:5000

# Set to "true" to bypass Azure AD and use the dev role-picker login screen.
# Must be "false" or absent in production builds.
VITE_DEV_AUTH=true
